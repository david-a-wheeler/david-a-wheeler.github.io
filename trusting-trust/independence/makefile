# Makefile to compile the DDC proof document automatically.
# We run pdflatex and bibtex in the required sequence to resolve all
# cross-references, citations, and dynamically generated files.

TARGET = assumption-independence-ddc
PDF = $(TARGET).pdf
SRC = $(TARGET).tex

# All LaTeX intermediates (aux, log, the filecontents-extracted .bib, the .bbl,
# and the build log) live in this subdirectory so they stay out of the source
# directory while remaining available for debugging. The final PDF is copied
# back out to the source directory for convenient viewing.
BUILDDIR = build
BUILDLOG = $(BUILDDIR)/build.log

# pdflatex's -output-directory sends every generated file (including the
# filecontents .bib) into $(BUILDDIR), and reads its own .aux/.bbl back from
# there, so the multi-pass page-break decision converges exactly as it does in a
# flat build. bibtex is the one tool that does NOT look in that directory on its
# own, so the recipe adds $(BUILDDIR) to BIBINPUTS; bibtex writes its .bbl next
# to the .aux, i.e. back into $(BUILDDIR).
LATEX = pdflatex -interaction=nonstopmode -output-directory=$(BUILDDIR)

# Default target
all: $(PDF)

# Compile loop to handle references properly.
# All processing output is captured in $(BUILDLOG) so the build stays quiet on
# the terminal; run "make check" (or read $(BUILDLOG)) to inspect problems.
# The pdflatex/bibtex lines are prefixed with '-' so that a failing pass still
# lets the summary run, surfacing the error instead of hiding it.
$(PDF): $(SRC)
	@mkdir -p $(BUILDDIR)
	-$(LATEX) $(TARGET) > $(BUILDLOG) 2>&1
	-BIBINPUTS="$(BUILDDIR):$$BIBINPUTS" bibtex $(BUILDDIR)/$(TARGET) >> $(BUILDLOG) 2>&1
	-$(LATEX) $(TARGET) >> $(BUILDLOG) 2>&1
	-$(LATEX) $(TARGET) >> $(BUILDLOG) 2>&1
	-@cp $(BUILDDIR)/$(PDF) $(PDF)
	@$(MAKE) --no-print-directory check

# Summarize errors and warnings from the most recent build, without rebuilding.
# Reads only $(BUILDLOG), so it is cheap to inspect after a build.
check:
	@test -f $(BUILDLOG) || { echo "No $(BUILDLOG); run 'make' first."; exit 0; }
	@echo "== $(BUILDLOG): final-pass errors, undefined refs/cites, overfull boxes =="
	@awk '/This is pdfTeX/{buf=""} {buf=buf $$0 ORS} END{printf "%s", buf}' $(BUILDLOG) \
		| grep -nE "^! |Overfull|Warning|undefined" || echo "  none found"

# Useful target to quickly view your compiled PDF on Linux
view: $(PDF)
	@if command -v xdg-open > /dev/null; then \
		xdg-open $(PDF); \
	else \
		echo "Could not find xdg-open. Please open $(PDF) manually."; \
	fi

# Clean up all of the auxiliary files generated by the LaTeX build process by
# removing the entire build directory (which also holds the extracted .bib).
clean:
	rm -rf $(BUILDDIR)

# Clean everything including the final PDF
distclean: clean
	rm -f $(PDF)

.PHONY: all check view clean distclean
